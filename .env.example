# ============================================================
# .env.example — 필요한 환경변수 목록
# 실제 값은 .env.local 에 채워서 사용하세요 (.env.local 은 gitignore 됨).
# Vercel 배포 환경에는 Vercel Settings > Environment Variables 에 동일하게 등록.
# ============================================================

# ───── 자체 대시보드 DB (Supabase) ─────
# Supabase 프로젝트의 Project URL
NEXT_PUBLIC_SUPABASE_URL=
# Anon(public) 키 — 클라이언트 노출 가능
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role 키 — 서버 전용. 절대 클라이언트로 노출 금지.
# (사용처: app/api/user-permissions 등)
SUPABASE_SERVICE_ROLE_KEY=

# ───── nlab 운영 DB (Supabase) ─────
# 강의/결제/사용자 데이터. 서버 전용 service_role 키 사용.
# (사용처: order-sync, sales-analysis, shoong-bulk 등)
NLAB_SUPABASE_URL=
NLAB_SUPABASE_SERVICE_ROLE_KEY=

# ───── Google Sheets API (서비스 계정) ─────
# Google Cloud Console > IAM > Service Accounts 에서 발급한 키 파일의 두 필드.
# 시트에 해당 서비스 계정을 편집자로 공유해야 동작.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# 줄바꿈 포함 PEM 전체. .env에 넣을 때는 \n 을 그대로 두거나 따옴표로 감싸기.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# ───── AI ─────
# Anthropic Claude API 키 (cs-ai, /api/analyze 등)
ANTHROPIC_API_KEY=
# Google Gemini API 키 (무료강의 분석기 — lecture-analyze-gemini)
GEMINI_API_KEY=
# 선택: Gemini 모델 오버라이드. 미설정 시 gemini-2.0-flash
# GEMINI_MODEL=gemini-2.0-flash

# ───── 슝(Shoong) 알림톡 ─────
# 슝 어드민(app.shoong.kr)에서 발급한 API 키 (Bearer 토큰)
SHOONG_API_KEY=
# 발신프로필 키 (카카오 채널과 매핑된 슝 senderkey)
SHOONG_SENDER_KEY=

# ───── 채널톡 ─────
# 채널톡 OpenAPI 액세스 키/시크릿 (cs-ai, channel-conversations)
CHANNEL_ACCESS_KEY=
CHANNEL_ACCESS_SECRET=
# 채널톡 → 우리 서버 webhook 인증 토큰. x-signature 헤더와 비교.
CHANNEL_WEBHOOK_TOKEN=
# 'true' 면 AI가 자동 답변, 그 외엔 추천(매니저 노트)만 전송
CHANNEL_AUTO_REPLY=false
